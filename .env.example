# ------------------------------------------------------------
# KukuSmart environment variables
# Copy this file to .env (or .env.local) and fill in real values.
# ------------------------------------------------------------

# Database (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Supabase (server-side storage access)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=""

# NextAuth v5
# Required for session/token encryption in production
AUTH_SECRET="replace-with-a-long-random-secret"

# OAuth providers (used by next-auth/providers/google and github)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# AI provider
GOOGLE_API_KEY=""
GOOGLE_MAPS_KEY=""

# Email (contact form via Nodemailer + Gmail App Password)
ORG_EMAIL="you@example.com"
APP_PASSWORD="your-gmail-app-password"

